# ── Buffer (Instagram scheduling) ───────────────────────────────────────────
BUFFER_TOKEN=          # Buffer API access token (required to post)
BUFFER_COOKIES=        # optional: exported Buffer session cookies (see extract_buffer_cookies.py)

# ── Synology (RAW source) ───────────────────────────────────────────────────
SYNO_HOST=             # e.g. https://nas.local:5001 (LAN address, tried first)
SYNO_HOST_FALLBACK=    # e.g. https://<name>.quickconnect.to — used when the LAN host is unreachable
SYNO_USER=
SYNO_PASS=
SYNO_OTP=              # 2FA one-time code, if your account requires it
SYNO_DEVICE_ID=        # optional: remembered-device id to skip the OTP prompt

# ── Local ───────────────────────────────────────────────────────────────────
MAC_HOME=              # home dir used to resolve Lightroom / export paths
